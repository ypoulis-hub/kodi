<?xml version="1.0" encoding="UTF-8"?>
<settings>
  <category label="Authentication">
    <setting id="auth_token" type="text" label="Auth Token (DAT cookie from browser)" default=""/>
    <setting id="access_token" type="text" label="Live Bearer Token (access_token cookie, optional)" default=""/>
  </category>
  <category label="Playback">
    <setting id="max_quality" type="enum" label="Max Video Quality" values="1080p|720p|540p|360p" default="0"/>
    <setting id="default_feed" type="enum" label="Default Camera Feed" values="Commentary|Ambient|Helicopter|Onboard 1|Onboard 2|Onboard 3|Onboard 4" default="0"/>
  </category>
  <category label="Content">
    <setting id="default_season" type="text" label="Default Season Year (empty = current)" default=""/>
  </category>
  <category label="Advanced">
    <setting id="debug_log" type="bool" label="Enable debug logging" default="false"/>
  </category>
</settings>
