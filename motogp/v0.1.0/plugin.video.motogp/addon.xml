<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.motogp"
       name="MotoGP VideoPass"
       version="0.1.0"
       provider-name="ypoul">
  <requires>
    <import addon="xbmc.python" version="3.0.1"/>
    <import addon="inputstream.adaptive" version="21.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">MotoGP VideoPass player for subscribers</summary>
    <description lang="en_GB">Browse and play MotoGP, Moto2, and Moto3 races, qualifying, and practice sessions from your VideoPass subscription. Multiple camera feeds including commentary, ambient, helicopter, and onboard cameras. Up to 1080p@50fps.</description>
    <platform>all</platform>
    <license>MIT</license>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
